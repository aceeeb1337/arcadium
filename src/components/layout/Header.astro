---
import { SITE } from '../../data/site';

// Active-state for top-level pages
const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => path === href.replace(/\/$/, '');

const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/pcgaming', label: 'PC Gaming' },
  { href: '/consolegaming', label: 'Console' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/tournaments', label: 'Tournaments' },
  { href: '/#gallery', label: 'Gallery' },
];
---

<header id="site-header" aria-label="Site header">
  <div class="header-bar">

    <a href="/" class="header-logo" aria-label={SITE.fullName}>
      <img src="/icons/logo.png" alt={SITE.name} width="109" height="44" class="logo-img" />
    </a>

    <nav id="pill-nav" aria-label="Main navigation" class="pill-nav">
      <ul role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[{ 'is-active': link.href.startsWith('/') && !link.href.includes('#') && isActive(link.href) }]}
              aria-current={link.href.startsWith('/') && !link.href.includes('#') && isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-right">
      <a
        href="/#location"
        class="book-cta"
        data-cursor="magnetic"
        aria-label="Find our location"
      >
        Find Us
      </a>

      <button
        id="nav-toggle"
        class="nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="bar bar-top"></span>
        <span class="bar bar-bot"></span>
      </button>
    </div>

  </div>
</header>

<div id="mobile-menu" aria-hidden="true" hidden>
  <nav aria-label="Mobile navigation">
    <ul role="list">
      {navLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href="/#location">Location</a></li>
    </ul>
    <a
      href={SITE.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary mobile-book-cta"
      aria-label="Book a session via WhatsApp"
    >
      Book Now
    </a>
  </nav>
</div>

<style>
  #site-header {
    position: fixed;
    top: calc(1.5rem + var(--ann-bar-height, 0px));
    left: 0;
    right: 0;
    z-index: 900;
    pointer-events: none;
    transition: top 0.2s ease;
  }

  .header-bar {
    pointer-events: all;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 2rem;
    width: 100%;
    max-width: clamp(1320px, 90vw, 2080px);
    margin: 0 auto;
  }

  .header-logo {
    display: flex;
    align-items: center;
    justify-self: start;
    grid-column: 1;
  }

  .logo-img {
    display: block;
    height: clamp(34px, 4vw, 48px);
    width: auto;
  }

  .pill-nav {
    display: none;
    align-items: center;
    height: 48px;
    padding: 0 1.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(13, 6, 20, 0.4);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 0.4s var(--ease-expo-out),
      transform 0.4s var(--ease-expo-out),
      border-color 0.4s ease,
      background 0.4s ease,
      box-shadow 0.4s ease;
  }

  .pill-nav.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 1024px) {
    .pill-nav {
      display: flex;
    }
  }

  .pill-nav.scrolled {
    background: rgba(13, 6, 20, 0.9);
    border-color: rgba(101, 40, 247, 0.35);
    box-shadow:
      0 0 0 1px rgba(101, 40, 247, 0.08),
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 50px rgba(101, 40, 247, 0.1);
  }

  .pill-nav ul {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pill-nav a {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(242, 240, 254, 0.55);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
    position: relative;
    white-space: nowrap;
  }

  .pill-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: #a78bfa;
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: center;
  }

  .pill-nav a:hover {
    color: #f2f0fe;
  }

  .pill-nav a:hover::after {
    transform: scaleX(1);
  }

  .pill-nav a.is-active {
    color: #f2f0fe;
  }

  .pill-nav a.is-active::after {
    transform: scaleX(1);
    background: var(--color-brand);
  }

  .header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    grid-column: 3;
  }

  .book-cta {
    display: none;
    padding: 0 1.25rem;
    height: 40px;
    border-radius: 999px;
    background: var(--color-brand);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    align-items: center;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: background 0.2s, box-shadow 0.2s;
  }

  .book-cta:hover {
    background: #7c3aff;
    box-shadow: 0 0 20px rgba(101, 40, 247, 0.5);
  }

  @media (min-width: 1024px) {
    .book-cta {
      display: flex;
    }
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 40px;
    height: 40px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 1024px) {
    .nav-toggle {
      display: none;
    }
  }

  .bar {
    display: block;
    width: 20px;
    height: 1.5px;
    background: rgba(242, 240, 254, 0.85);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s;
    transform-origin: center;
  }

  .nav-toggle[aria-expanded='true'] .bar-top {
    transform: translateY(3.75px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .bar-bot {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  #mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 800;
    background: rgba(13, 6, 20, 0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  #mobile-menu[hidden] {
    display: none;
  }

  #mobile-menu nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 320px;
  }

  #mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    text-align: center;
  }

  #mobile-menu li {
    border-bottom: 1px solid rgba(101, 40, 247, 0.12);
  }

  #mobile-menu li:first-child {
    border-top: 1px solid rgba(101, 40, 247, 0.12);
  }

  #mobile-menu nav a {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 1.375rem;
    font-weight: 600;
    color: rgba(242, 240, 254, 0.75);
    text-decoration: none;
    padding: 1rem 0;
    transition: color 0.2s, padding-left 0.2s;
    letter-spacing: -0.01em;
  }

  #mobile-menu li a:hover {
    color: #f2f0fe;
    padding-left: 0.5rem;
  }

  .mobile-book-cta {
    margin-top: 2rem;
    width: 100%;
    justify-content: center;
    text-align: center;
  }
</style>

<script>
  const pill = document.getElementById('pill-nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-menu')!;

  const onScroll = () => {
    const y = window.scrollY;
    pill.classList.toggle('is-visible', y > 80);
    pill.classList.toggle('scrolled', y > 80);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu.setAttribute('aria-hidden', String(isOpen));
    if (isOpen) {
      menu.setAttribute('hidden', '');
      document.body.style.overflow = '';
    } else {
      menu.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    }
  });

  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.pill-nav a[href^="/#"]');

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navLinks.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('href') === `/#${id}`);
          });
        }
      });
    },
    { rootMargin: '-35% 0px -60% 0px', threshold: 0 }
  );

  document.querySelectorAll<HTMLElement>('section[id]').forEach((s) => sectionObserver.observe(s));

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('hidden', '');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
</script>
