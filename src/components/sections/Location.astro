---
import SectionLabel from '../ui/SectionLabel.astro';
import { SITE, SOCIALS } from '../../data/site';
import { Icon } from 'astro-icon/components';
---

<section id="location" class="section-pad" aria-label="Location and contact">
  <div class="container">
    <div class="location-header" data-reveal>
      <SectionLabel label="Location" />
      <h2 class="section-heading">
        Find us in<br /><span class="gradient-text">Karachi</span>
      </h2>
      <p class="location-open">Open 24/7. Walk in any time, no appointment needed.</p>
    </div>

    <div class="location-grid">
      <div class="location-info" data-reveal>
        <div class="info-block">
          <div class="info-icon" aria-hidden="true">
            <Icon name="ri:map-pin-line" width={20} height={20} />
          </div>
          <div>
            <p class="info-label">Address</p>
            <address class="info-value not-italic">
              {SITE.address.line1},<br />
              {SITE.address.line2},<br />
              {SITE.address.city}, {SITE.address.country}
            </address>
          </div>
        </div>

        <div class="info-block">
          <div class="info-icon" aria-hidden="true">
            <Icon name="ri:phone-line" width={20} height={20} />
          </div>
          <div>
            <p class="info-label">Phone / WhatsApp</p>
            <a href={SITE.whatsappUrl} class="info-value info-link" target="_blank" rel="noopener noreferrer">
              {SITE.phone}
            </a>
          </div>
        </div>

        <div class="info-block">
          <div class="info-icon" aria-hidden="true">
            <Icon name="ri:time-line" width={20} height={20} />
          </div>
          <div>
            <p class="info-label">Opening Hours</p>
            <ul class="hours-list" role="list">
              {SITE.hours.map((h) => (
                <li>
                  <span class="hours-days">{h.days}</span>
                  <span class="hours-time">{h.time}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="info-block">
          <div class="info-icon" aria-hidden="true">
            <Icon name="ri:share-line" width={20} height={20} />
          </div>
          <div>
            <p class="info-label">Follow Us</p>
            <div class="location-socials">
              {SOCIALS.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${SITE.name} on ${s.name}`}
                  class="social-pill"
                >
                  <Icon name={s.icon} width={16} height={16} />
                  {s.name}
                </a>
              ))}
            </div>
            <a
              href="https://www.linkedin.com/in/haseebesports/"
              target="_blank"
              rel="noopener noreferrer"
              class="founder-link"
            >
              Meet the Founder ↗
            </a>
          </div>
        </div>

        <a
          href={SITE.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary location-cta"
          data-cursor="magnetic"
          aria-label="Book a session via WhatsApp"
        >
          <Icon name="ri:whatsapp-line" width={18} height={18} aria-hidden="true" />
          Book via WhatsApp
        </a>
      </div>

      <div class="location-map" data-reveal>
        <div class="map-wrapper">
          <iframe
            src={SITE.mapsEmbedUrl}
            title="Arcadium by ViderGG location on Google Maps"
            width="800"
            height="600"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #location {
    overflow: hidden;
  }

  .location-header {
    max-width: 600px;
    margin-bottom: 4rem;
  }

  .location-open {
    margin-top: 1rem;
    font-size: 1.0625rem;
    color: var(--color-brand-light);
    font-weight: 500;
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .location-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .location-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 10px;
    background: rgba(101, 40, 247, 0.12);
    border: 1px solid rgba(101, 40, 247, 0.25);
    color: var(--color-brand-light);
  }

  .info-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: 0.375rem;
  }

  .info-value {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .info-link {
    color: var(--color-brand-light);
    text-decoration: none;
    transition: color 0.2s;
  }

  .info-link:hover {
    color: white;
  }

  .hours-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .hours-days {
    color: rgba(242, 240, 254, 0.6);
  }

  .hours-time {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .location-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition:
      border-color 0.2s,
      color 0.2s,
      box-shadow 0.2s;
  }

  .social-pill:hover {
    border-color: var(--color-brand);
    color: white;
    box-shadow: 0 0 12px rgba(101, 40, 247, 0.3);
  }

  .founder-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-dim);
    text-decoration: none;
    margin-top: 0.75rem;
    transition: color 0.2s;
  }

  .founder-link:hover {
    color: var(--color-brand-light);
  }

  .location-cta {
    margin-top: 0.5rem;
    width: fit-content;
  }

  .map-wrapper {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    aspect-ratio: 4/3;
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
