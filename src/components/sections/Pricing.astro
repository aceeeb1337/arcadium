---
import SectionLabel from '../ui/SectionLabel.astro';
import { categories } from '../../data/pricing';
import { SITE } from '../../data/site';
---

<section id="pricing" class="section-pad" aria-label="Pricing">
  <div class="container">
    <div class="pricing-header" data-reveal>
      <SectionLabel label="Pricing" />
      <h2 class="section-heading">
        Simple pricing,<br /><span class="gradient-text">no hidden fees</span>
      </h2>
      <p class="pricing-sub">
        Walk in or book a pack — every session includes a private room, high-speed internet, and full peripheral setup.
      </p>
    </div>

    <div class="pricing-grid">
      {categories.map((cat) => {
        const href = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(cat.whatsappMessage)}`;
        const btnClass = cat.accent === 'purple' ? 'btn-primary pricing-cta' : 'btn-ghost pricing-cta';
        return (
          <div class:list={['pricing-card glass-card', `cat-${cat.accent}`]} data-reveal>
            <div class="pricing-card-head">
              <div>
                <h3 class="pricing-name">{cat.name}</h3>
                <p class="pricing-tagline">{cat.tagline}</p>
              </div>
              <span class="pricing-rate">{cat.ratePerHour}</span>
            </div>

            <div class="pricing-tiers">
              <p class="pricing-tiers-label">Packs</p>
              {cat.tiers.map((tier) => (
                <div class:list={['pricing-tier', { 'tier-hot': tier.highlight }]}>
                  <span class="tier-dur">{tier.duration}</span>
                  <div class="tier-right">
                    {tier.priceNote && <span class="tier-note">{tier.priceNote}</span>}
                    <span class="tier-price">{tier.price}</span>
                  </div>
                </div>
              ))}
            </div>

            <a href={href} target="_blank" rel="noopener noreferrer" class={btnClass} data-cursor="magnetic">
              Book {cat.name}
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .pricing-header { max-width: 640px; margin-bottom: 3rem; }

  .pricing-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    max-width: 54ch;
    margin-top: 1rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }

  .pricing-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: transform 0.3s var(--ease-expo-out), box-shadow 0.3s;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(101, 40, 247, 0.2);
  }

  .cat-blue   { border-color: rgba(56, 139, 253, 0.3) !important; }
  .cat-purple {
    border-color: rgba(101, 40, 247, 0.45) !important;
    background: linear-gradient(160deg, rgba(101, 40, 247, 0.1) 0%, rgba(13, 6, 20, 0.92) 60%) !important;
  }
  .cat-pink   { border-color: rgba(236, 72, 153, 0.35) !important; }

  .pricing-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .pricing-name {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .pricing-tagline {
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    margin-top: 0.25rem;
  }

  .pricing-rate {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-light);
    white-space: nowrap;
    background: rgba(101, 40, 247, 0.12);
    border: 1px solid rgba(101, 40, 247, 0.25);
    border-radius: 6px;
    padding: 0.3rem 0.65rem;
    flex-shrink: 0;
  }

  .pricing-tiers {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 0.875rem;
    flex: 1;
  }

  .pricing-tiers-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: 0.375rem;
  }

  .pricing-tier {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 0.65rem;
    border-radius: 8px;
    font-size: 0.8125rem;
    gap: 0.5rem;
  }

  .tier-hot { background: rgba(101, 40, 247, 0.12); }

  .tier-dur { color: var(--color-text-dim); }

  .tier-right { display: flex; align-items: center; gap: 0.4rem; }

  .tier-note {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-light);
    background: rgba(101, 40, 247, 0.15);
    border-radius: 4px;
    padding: 0.15rem 0.35rem;
  }

  .tier-price {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .pricing-cta {
    width: 100%;
    justify-content: center;
    text-align: center;
    margin-top: auto;
  }
</style>