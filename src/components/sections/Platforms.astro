---
import SectionLabel from '../ui/SectionLabel.astro';
import { platforms } from '../../data/platforms';
import { Icon } from 'astro-icon/components';
---

<section id="platforms" class="section-pad" aria-label="Gaming Platforms">
  <div class="container">
    <div class="platforms-glow" aria-hidden="true"></div>

    <div class="platforms-header" data-reveal>
      <SectionLabel label="Platforms" />
      <h2 class="section-heading">
        PC or console,<br /><span class="gradient-text">we have it</span>
      </h2>
      <p class="platforms-sub">
        High-end gaming PCs and PlayStation 5 under one roof. Pick your platform and play.
      </p>
    </div>

    <div class="platforms-grid">
      {platforms.map((p) => (
        <article class="platform-card glass-card" data-reveal aria-label={p.name}>
          <div class="platform-icon" aria-hidden="true">
            <Icon name={p.icon} width={40} height={40} />
          </div>
          <h3 class="platform-name">{p.name}</h3>
          <p class="platform-desc">{p.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  #platforms {
    position: relative;
    overflow: hidden;
  }

  .platforms-glow {
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: clamp(300px, 55vw, 600px);
    height: clamp(300px, 55vw, 600px);
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(101,40,247,0.4) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(60px);
    opacity: 0.25;
  }

  .platforms-header {
    max-width: 640px;
    margin-bottom: 4rem;
  }

  .platforms-sub {
    font-size: 1.0625rem;
    color: var(--color-text-dim);
    max-width: 52ch;
    margin-top: 1rem;
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 860px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .platforms-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .platform-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition:
      border-color 0.3s,
      box-shadow 0.3s,
      transform 0.3s var(--ease-expo-out);
  }

  .platform-card:hover {
    border-color: rgba(101, 40, 247, 0.5);
    box-shadow: 0 8px 40px rgba(101, 40, 247, 0.2);
    transform: translateY(-4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .platform-card:hover {
      transform: none;
    }
  }

  .platform-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: rgba(101, 40, 247, 0.12);
    border: 1px solid rgba(101, 40, 247, 0.25);
    color: var(--color-brand-light);
    transition: background 0.3s, box-shadow 0.3s;
  }

  .platform-card:hover .platform-icon {
    background: rgba(101, 40, 247, 0.2);
    box-shadow: 0 0 20px rgba(101, 40, 247, 0.3);
  }

  .platform-name {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .platform-desc {
    font-size: 0.9375rem;
    color: rgba(242, 240, 254, 0.55);
    line-height: 1.65;
    flex: 1;
  }

</style>
