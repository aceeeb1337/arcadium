---
import SectionLabel from '../ui/SectionLabel.astro';
import { specs } from '../../data/specs';
---

<section id="specs" class="section-pad" aria-label="PC Specifications">
  <div class="container">
    <div class="specs-header" data-reveal>
      <SectionLabel label="Specs" />
      <h2 class="section-heading">
        Built for the<br /><span class="gradient-text">uncompromising</span>
      </h2>
      <p class="specs-sub">
        Every machine is hand-picked for competitive performance. No mid-range compromises.
      </p>
    </div>

    <div class="specs-grid">
      {specs.map((spec) => (
        <div
          class:list={['spec-card glass-card', { 'spec-highlight': spec.highlight }]}
          data-reveal
          role="listitem"
        >
          {spec.highlight && (
            <div class="spec-badge">Pakistan's First</div>
          )}
          <p class="spec-label">{spec.label}</p>
          <div class="spec-value-wrap">
            <span
              class:list={['spec-value', { 'gradient-text': spec.highlight }]}
              data-spec-value={spec.highlight ? spec.value : undefined}
            >
              {spec.value}
            </span>
            {spec.unit && (
              <span class="spec-unit">{spec.unit}</span>
            )}
          </div>
          <p class="spec-desc">{spec.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #specs {
    overflow: hidden;
  }

  .specs-header {
    max-width: 640px;
    margin-bottom: 4rem;
  }

  .specs-sub {
    font-size: 1.0625rem;
    color: var(--color-text-dim);
    max-width: 48ch;
    margin-top: 1rem;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .specs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .specs-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .spec-card {
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s, box-shadow 0.3s;
    min-height: 280px;
  }

  .spec-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 8px 40px rgba(101, 40, 247, 0.3);
  }

  .spec-highlight {
    border-color: rgba(101, 40, 247, 0.5) !important;
    background: rgba(101, 40, 247, 0.06);
  }

  .spec-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(101, 40, 247, 0.2);
    border: 1px solid rgba(101, 40, 247, 0.4);
    color: var(--color-brand-light);
    width: fit-content;
  }

  .spec-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .spec-value-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .spec-value {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .spec-unit {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .spec-desc {
    font-size: 0.9375rem;
    color: rgba(242, 240, 254, 0.55);
    line-height: 1.6;
    margin-top: auto;
  }
</style>
