---
import MainLayout from '../../layouts/MainLayout.astro';
const WORKER = 'https://arcadium-website.fireonnoob.workers.dev';
---

<MainLayout title="Admin — Arcadium Tournaments">
  <div class="admin-page">

    <!-- Login -->
    <div class="login-wrap" id="login-wrap">
      <div class="login-card glass-card">
        <h1 class="login-title">Admin Access</h1>
        <p class="login-sub">Arcadium Tournament Management</p>
        <div class="field-group">
          <label>Admin Password</label>
          <input type="password" id="admin-pass" placeholder="Enter password" />
        </div>
        <button class="btn-primary login-btn" id="login-btn">Login</button>
        <p class="login-err" id="login-err" style="display:none">Incorrect password.</p>
      </div>
    </div>

    <!-- Dashboard -->
    <div class="admin-wrap" id="admin-wrap" style="display:none">
      <div class="admin-sidebar">
        <div class="sidebar-logo">Arcadium Admin</div>
        <nav class="sidebar-nav">
          <button class="nav-item active" data-tab="tournaments">Tournaments</button>
          <button class="nav-item" data-tab="registrations">Registrations</button>
        </nav>
        <button class="btn-ghost logout-btn" id="logout-btn">Logout</button>
      </div>

      <div class="admin-main">

        <!-- Tournaments Tab -->
        <div class="tab-panel" id="tab-tournaments">
          <div class="panel-header">
            <h2 class="panel-title">Tournaments</h2>
            <button class="btn-primary" id="new-tour-btn">+ New Tournament</button>
          </div>

          <!-- Create/Edit Form -->
          <div class="tour-form glass-card" id="tour-form" style="display:none">
            <h3 class="form-title" id="form-title">New Tournament</h3>
            <input type="hidden" id="edit-id" />
            <div class="form-grid">
              <div class="field-group">
                <label>Name *</label>
                <input type="text" id="f-name" placeholder="Arcadium Clash" />
              </div>
              <div class="field-group">
                <label>Game *</label>
                <select id="f-game">
                  <option value="">Select game</option>
                  <option value="CS2">CS2</option>
                  <option value="Valorant">Valorant</option>
                  <option value="Dota 2">Dota 2</option>
                  <option value="Tekken 8">Tekken 8</option>
                  <option value="EA FC 25">EA FC 25</option>
                </select>
              </div>
              <div class="field-group">
                <label>Start Date & Time *</label>
                <input type="datetime-local" id="f-date" />
              </div>
              <div class="field-group">
                <label>Registration Deadline</label>
                <input type="datetime-local" id="f-reg-deadline" />
              </div>
              <div class="field-group">
                <label>Status *</label>
                <select id="f-status">
                  <option value="upcoming">Upcoming</option>
                  <option value="registration_open">Registration Open</option>
                  <option value="ongoing">Ongoing</option>
                  <option value="completed">Completed</option>
                </select>
              </div>
              <div class="field-group">
                <label>Prize Pool</label>
                <input type="text" id="f-prize" placeholder="Rs 50,000" />
              </div>
              <div class="field-group">
                <label>Entry Fee</label>
                <input type="text" id="f-entry" placeholder="Rs 500 / team" />
              </div>
              <div class="field-group">
                <label>Slots</label>
                <input type="number" id="f-slots" placeholder="16" />
              </div>
              <div class="field-group">
                <label>Format</label>
                <input type="text" id="f-format" placeholder="5v5 Double Elimination" />
              </div>
              <div class="field-group">
                <label>Challonge URL</label>
                <input type="url" id="f-challonge" placeholder="https://challonge.com/..." />
              </div>
              <div class="field-group full-width">
                <label>Slug (auto-generated if blank)</label>
                <input type="text" id="f-slug" placeholder="arcadium-clash-2026" />
              </div>
              <div class="field-group full-width">
                <label>Description</label>
                <textarea id="f-desc" rows="3" placeholder="Tournament description..."></textarea>
              </div>
            </div>
            <div class="form-actions">
              <button class="btn-ghost" id="cancel-form-btn">Cancel</button>
              <button class="btn-primary" id="save-tour-btn">Save Tournament</button>
            </div>
            <p class="form-err" id="form-err" style="display:none"></p>
          </div>

          <!-- Tournament list -->
          <div id="tour-list"><div class="loading">Loading...</div></div>
        </div>

        <!-- Registrations Tab -->
        <div class="tab-panel" id="tab-registrations" style="display:none">
          <div class="panel-header">
            <h2 class="panel-title">Registrations</h2>
            <select id="reg-filter" class="filter-select">
              <option value="">All Tournaments</option>
            </select>
          </div>
          <div id="reg-list"><div class="loading">Loading...</div></div>
        </div>

      </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ WORKER }}>
  let adminToken = '';
  let tournaments = [];

  // ── Auth ──────────────────────────────────────────────────────────────────
  document.getElementById('login-btn').addEventListener('click', async () => {
    const pass = document.getElementById('admin-pass').value;
    // Test with a dummy request
    const res = await fetch(`${WORKER}/admin/tournaments`, {
      headers: { Authorization: `Bearer ${pass}` },
    });
    if (res.ok) {
      adminToken = pass;
      sessionStorage.setItem('arcadium_admin', pass);
      showDashboard();
    } else {
      document.getElementById('login-err').style.display = 'block';
    }
  });

  document.getElementById('admin-pass').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('login-btn').click();
  });

  document.getElementById('logout-btn').addEventListener('click', () => {
    sessionStorage.removeItem('arcadium_admin');
    adminToken = '';
    document.getElementById('admin-wrap').style.display = 'none';
    document.getElementById('login-wrap').style.display = 'flex';
  });

  // Auto-login if session exists
  const saved = sessionStorage.getItem('arcadium_admin');
  if (saved) { adminToken = saved; showDashboard(); }

  async function api(method, path, body = null) {
    const res = await fetch(`${WORKER}${path}`, {
      method,
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${adminToken}` },
      body: body ? JSON.stringify(body) : null,
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Request failed');
    return data;
  }

  function showDashboard() {
    document.getElementById('login-wrap').style.display = 'none';
    document.getElementById('admin-wrap').style.display = 'flex';
    loadTournaments();
    loadRegistrations();
  }

  // ── Tabs ─────────────────────────────────────────────────────────────────
  document.querySelectorAll('.nav-item').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).style.display = 'block';
    });
  });

  // ── Tournaments ──────────────────────────────────────────────────────────
  async function loadTournaments() {
    try {
      tournaments = await api('GET', '/admin/tournaments');
      renderTournamentList();
      populateFilter();
    } catch (e) {
      document.getElementById('tour-list').innerHTML = `<p class="err-txt">${e.message}</p>`;
    }
  }

  function renderTournamentList() {
    const statusColors = { upcoming: '#818cf8', registration_open: '#4ade80', ongoing: '#f59e0b', completed: '#6b7280' };
    const statusLabels = { upcoming: 'Upcoming', registration_open: 'Reg. Open', ongoing: 'Ongoing', completed: 'Completed' };
    document.getElementById('tour-list').innerHTML = tournaments.length ? `
      <div class="data-table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th><th>Game</th><th>Date</th><th>Status</th><th>Prize</th><th>Slots</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            ${tournaments.map(t => `
              <tr>
                <td><strong>${t.name}</strong><br><span class="slug-txt">${t.slug}</span></td>
                <td>${t.game}</td>
                <td>${t.start_date ? new Date(t.start_date).toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' }) : 'TBA'}</td>
                <td><span class="status-badge" style="color:${statusColors[t.status]}">${statusLabels[t.status]}</span></td>
                <td>${t.prize_pool || '—'}</td>
                <td>${t.slots || '—'}</td>
                <td class="action-cell">
                  <button class="action-btn edit-btn" data-id="${t.id}">Edit</button>
                  <button class="action-btn del-btn" data-id="${t.id}" data-name="${t.name}">Delete</button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    ` : '<p class="empty-txt">No tournaments yet. Create one above.</p>';

    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => openEditForm(btn.dataset.id));
    });
    document.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', () => deleteTournament(btn.dataset.id, btn.dataset.name));
    });
  }

  document.getElementById('new-tour-btn').addEventListener('click', () => {
    clearForm();
    document.getElementById('form-title').textContent = 'New Tournament';
    document.getElementById('edit-id').value = '';
    document.getElementById('tour-form').style.display = 'block';
    document.getElementById('tour-form').scrollIntoView({ behavior: 'smooth' });
  });

  document.getElementById('cancel-form-btn').addEventListener('click', () => {
    document.getElementById('tour-form').style.display = 'none';
    clearForm();
  });

  function clearForm() {
    ['f-name','f-game','f-date','f-reg-deadline','f-status','f-prize','f-entry','f-slots','f-format','f-challonge','f-slug','f-desc'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    document.getElementById('f-status').value = 'upcoming';
    document.getElementById('form-err').style.display = 'none';
  }

  function openEditForm(id) {
    const t = tournaments.find(t => t.id === id);
    if (!t) return;
    document.getElementById('form-title').textContent = 'Edit Tournament';
    document.getElementById('edit-id').value = t.id;
    document.getElementById('f-name').value = t.name || '';
    document.getElementById('f-game').value = t.game || '';
    document.getElementById('f-date').value = t.start_date ? t.start_date.slice(0,16) : '';
    document.getElementById('f-reg-deadline').value = t.registration_deadline ? t.registration_deadline.slice(0,16) : '';
    document.getElementById('f-status').value = t.status || 'upcoming';
    document.getElementById('f-prize').value = t.prize_pool || '';
    document.getElementById('f-entry').value = t.entry_fee || '';
    document.getElementById('f-slots').value = t.slots || '';
    document.getElementById('f-format').value = t.format || '';
    document.getElementById('f-challonge').value = t.challonge_url || '';
    document.getElementById('f-slug').value = t.slug || '';
    document.getElementById('f-desc').value = t.description || '';
    document.getElementById('tour-form').style.display = 'block';
    document.getElementById('tour-form').scrollIntoView({ behavior: 'smooth' });
  }

  document.getElementById('save-tour-btn').addEventListener('click', async () => {
    const id = document.getElementById('edit-id').value;
    const errEl = document.getElementById('form-err');
    errEl.style.display = 'none';

    const body = {
      name: document.getElementById('f-name').value.trim(),
      game: document.getElementById('f-game').value,
      start_date: document.getElementById('f-date').value || null,
      registration_deadline: document.getElementById('f-reg-deadline').value || null,
      status: document.getElementById('f-status').value,
      prize_pool: document.getElementById('f-prize').value.trim() || null,
      entry_fee: document.getElementById('f-entry').value.trim() || null,
      slots: document.getElementById('f-slots').value ? parseInt(document.getElementById('f-slots').value) : null,
      format: document.getElementById('f-format').value.trim() || null,
      challonge_url: document.getElementById('f-challonge').value.trim() || null,
      slug: document.getElementById('f-slug').value.trim() || null,
      description: document.getElementById('f-desc').value.trim() || null,
    };

    if (!body.name || !body.game) {
      errEl.textContent = 'Name and game are required.';
      errEl.style.display = 'block';
      return;
    }

    try {
      if (id) {
        await api('PUT', `/admin/tournaments/${id}`, body);
      } else {
        await api('POST', '/admin/tournaments', body);
      }
      document.getElementById('tour-form').style.display = 'none';
      clearForm();
      loadTournaments();
    } catch (e) {
      errEl.textContent = e.message;
      errEl.style.display = 'block';
    }
  });

  async function deleteTournament(id, name) {
    if (!confirm(`Delete "${name}"? This will also delete all registrations for this tournament.`)) return;
    try {
      await api('DELETE', `/admin/tournaments/${id}`);
      loadTournaments();
    } catch (e) {
      alert('Delete failed: ' + e.message);
    }
  }

  // ── Registrations ────────────────────────────────────────────────────────
  async function loadRegistrations(tournamentId = '') {
    try {
      const path = tournamentId ? `/admin/registrations?tournament_id=${tournamentId}` : '/admin/registrations';
      const regs = await api('GET', path);
      renderRegistrations(regs);
    } catch (e) {
      document.getElementById('reg-list').innerHTML = `<p class="err-txt">${e.message}</p>`;
    }
  }

  function populateFilter() {
    const sel = document.getElementById('reg-filter');
    sel.innerHTML = '<option value="">All Tournaments</option>';
    tournaments.forEach(t => {
      sel.innerHTML += `<option value="${t.id}">${t.name}</option>`;
    });
  }

  document.getElementById('reg-filter').addEventListener('change', e => {
    loadRegistrations(e.target.value);
  });

  function renderRegistrations(regs) {
    const statusColors = { pending: '#f59e0b', approved: '#4ade80', rejected: '#f87171' };
    document.getElementById('reg-list').innerHTML = regs.length ? `
      <div class="data-table-wrap">
        <table class="data-table">
          <thead>
            <tr><th>Tournament</th><th>Game</th><th>Team / Name</th><th>Registered</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            ${regs.map(r => {
              const name = r.team_name || r.solo_name || '—';
              const tourName = r.tournaments?.name || '—';
              const date = new Date(r.created_at).toLocaleDateString('en-PK', { day: 'numeric', month: 'short' });
              return `
                <tr>
                  <td>${tourName}</td>
                  <td>${r.game}</td>
                  <td><strong>${name}</strong></td>
                  <td>${date}</td>
                  <td>
                    <select class="status-sel" data-id="${r.id}" data-status="${r.status}" style="color:${statusColors[r.status]}">
                      <option value="pending" ${r.status==='pending'?'selected':''}>Pending</option>
                      <option value="approved" ${r.status==='approved'?'selected':''}>Approved</option>
                      <option value="rejected" ${r.status==='rejected'?'selected':''}>Rejected</option>
                    </select>
                  </td>
                  <td class="action-cell">
                    <button class="action-btn view-btn" data-reg='${JSON.stringify(r).replace(/'/g,"\\'")}'>View</button>
                    <button class="action-btn del-btn" data-id="${r.id}">Delete</button>
                  </td>
                </tr>
              `;
            }).join('')}
          </tbody>
        </table>
      </div>
    ` : '<p class="empty-txt">No registrations yet.</p>';

    document.querySelectorAll('.status-sel').forEach(sel => {
      sel.addEventListener('change', async () => {
        try {
          await api('PUT', `/admin/registrations/${sel.dataset.id}`, { status: sel.value });
          sel.style.color = { pending: '#f59e0b', approved: '#4ade80', rejected: '#f87171' }[sel.value];
        } catch (e) { alert('Update failed: ' + e.message); }
      });
    });

    document.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const r = JSON.parse(btn.dataset.reg);
        showRegModal(r);
      });
    });

    document.querySelectorAll('#reg-list .del-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this registration?')) return;
        try {
          await api('DELETE', `/admin/registrations/${btn.dataset.id}`);
          loadRegistrations(document.getElementById('reg-filter').value);
        } catch (e) { alert('Delete failed: ' + e.message); }
      });
    });
  }

  function showRegModal(r) {
    const existing = document.getElementById('reg-modal');
    if (existing) existing.remove();

    const isTeam = ['CS2', 'Valorant', 'Dota 2'].includes(r.game);
    let content = '';

    if (isTeam) {
      const players = [1,2,3,4,5].map(i => `
        <div class="modal-player">
          <strong>Player ${i}</strong>
          <span>${r[`p${i}_name`] || '—'}</span>
          <span class="dim">@${r[`p${i}_nick`] || '—'}</span>
          <span class="dim">${r[`p${i}_phone`] || '—'} · WA: ${r[`p${i}_wa`] || '—'}</span>
        </div>
      `).join('');
      const sub = r.sub_name ? `<div class="modal-player"><strong>Substitute</strong><span>${r.sub_name}</span><span class="dim">@${r.sub_nick || '—'}</span><span class="dim">${r.sub_phone || '—'}</span></div>` : '';
      content = `<p class="modal-team">Team: <strong>${r.team_name}</strong></p>${players}${sub}`;
    } else {
      content = `<p>Name: <strong>${r.solo_name}</strong></p><p>Phone: <strong>${r.solo_phone}</strong></p>`;
    }

    const modal = document.createElement('div');
    modal.id = 'reg-modal';
    modal.className = 'modal-overlay';
    modal.innerHTML = `
      <div class="modal-box glass-card">
        <div class="modal-head">
          <h3>${r.game} Registration</h3>
          <button class="modal-close" id="modal-close">✕</button>
        </div>
        <div class="modal-body">${content}</div>
      </div>
    `;
    document.body.appendChild(modal);
    document.getElementById('modal-close').addEventListener('click', () => modal.remove());
    modal.addEventListener('click', e => { if (e.target === modal) modal.remove(); });
  }
</script>

<style>
  .admin-page { min-height: 100vh; }

  .login-wrap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .login-card {
    padding: 3rem;
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .login-title { font-family: 'Inter', sans-serif; font-size: 1.75rem; font-weight: 700; color: var(--color-text); }
  .login-sub { color: var(--color-text-dim); font-size: 0.9rem; margin-top: -1rem; }
  .login-btn { width: 100%; justify-content: center; }
  .login-err { color: #f87171; font-size: 0.875rem; text-align: center; }

  .admin-wrap {
    display: flex;
    min-height: 100vh;
    padding-top: var(--header-height);
  }

  .admin-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.02);
    border-right: 1px solid var(--color-border);
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: var(--header-height);
    height: calc(100vh - var(--header-height));
  }
  .sidebar-logo { font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 700; color: var(--color-brand-light); }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.375rem; flex: 1; }
  .nav-item {
    text-align: left;
    padding: 0.65rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-dim);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .nav-item:hover { background: rgba(255,255,255,0.05); color: var(--color-text); }
  .nav-item.active { background: rgba(101,40,247,0.15); color: var(--color-brand-light); }
  .logout-btn { font-size: 0.875rem; padding: 0.6rem 1rem; }

  .admin-main { flex: 1; padding: 2.5rem; overflow-y: auto; }

  .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
  .panel-title { font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--color-text); }

  .tour-form {
    padding: 2rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-title { font-family: 'Inter', sans-serif; font-size: 1.125rem; font-weight: 700; color: var(--color-text); }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 1100px) { .form-grid { grid-template-columns: repeat(3, 1fr); } }
  .full-width { grid-column: 1/-1; }
  .form-actions { display: flex; gap: 1rem; justify-content: flex-end; }
  .form-err { color: #f87171; font-size: 0.875rem; }

  .field-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .field-group label { font-size: 0.8125rem; font-weight: 600; color: var(--color-text-dim); }
  .field-group input, .field-group select, .field-group textarea {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.7rem 0.875rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: inherit;
    width: 100%;
  }
  .field-group input:focus, .field-group select:focus, .field-group textarea:focus {
    outline: none;
    border-color: var(--color-brand);
  }
  .field-group select option { background: #0d0614; }

  .data-table-wrap { overflow-x: auto; }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .data-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    border-bottom: 1px solid var(--color-border);
  }
  .data-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(101,40,247,0.08);
    color: rgba(242,240,254,0.8);
    vertical-align: middle;
  }
  .data-table tr:hover td { background: rgba(255,255,255,0.02); }
  .slug-txt { font-size: 0.75rem; color: var(--color-text-dim); font-family: monospace; }
  .status-badge { font-weight: 600; font-size: 0.8125rem; }
  .action-cell { display: flex; gap: 0.5rem; }
  .action-btn {
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-dim);
    transition: all 0.2s;
  }
  .edit-btn:hover { border-color: var(--color-brand); color: var(--color-brand-light); }
  .del-btn:hover { border-color: #f87171; color: #f87171; }

  .status-sel {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
    font-size: 0.8125rem;
