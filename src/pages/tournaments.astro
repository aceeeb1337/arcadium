---
import MainLayout from '../layouts/MainLayout.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';

const WORKER = 'https://arcadium-website.fireonnoob.workers.dev';
---

<MainLayout title="Tournaments — Arcadium" description="Join weekly esports tournaments at Arcadium Karachi. CS2, Valorant, Tekken 8, EA FC 25 and Dota 2.">
  <section class="tour-page section-pad">
    <div class="container">
      <div class="page-hero" data-reveal>
        <SectionLabel label="Compete" />
        <h1 class="section-heading">
          Tournaments<br /><span class="gradient-text">at Arcadium</span>
        </h1>
        <p class="page-sub">
          Weekly brackets across PC and PS5. Cash prize pools, proper formats, and Karachi's most competitive players.
        </p>
      </div>

      <div class="tour-section">
        <h2 class="tour-section-title" data-reveal>Upcoming Tournaments</h2>
        <div class="tour-grid" id="upcoming-grid">
          <div class="loading-state">Loading tournaments...</div>
        </div>
      </div>

      <div class="tour-section">
        <h2 class="tour-section-title" data-reveal>Past Tournaments</h2>
        <div class="tour-grid past-grid" id="past-grid">
          <div class="loading-state">Loading...</div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script define:vars={{ WORKER }}>
  const statusLabel = {
    upcoming: 'Coming Soon',
    registration_open: 'Registration Open',
    ongoing: 'Ongoing',
    completed: 'Completed',
  };

  const statusColor = {
    upcoming: 'st-upcoming',
    registration_open: 'st-open',
    ongoing: 'st-ongoing',
    completed: 'st-done',
  };

  const gameAccent = {
    'CS2': 'acc-blue',
    'Valorant': 'acc-pink',
    'Dota 2': 'acc-purple',
    'Tekken 8': 'acc-pink',
    'EA FC 25': 'acc-blue',
  };

  const gamePlatform = {
    'CS2': 'PC',
    'Valorant': 'PC',
    'Dota 2': 'PC',
    'Tekken 8': 'PS5',
    'EA FC 25': 'PS5',
  };

  function card(t, isPast) {
    const accent = gameAccent[t.game] || 'acc-purple';
    const stClass = statusColor[t.status] || 'st-open';
    const label = statusLabel[t.status] || t.status;
    const platform = gamePlatform[t.game] || 'PC';
    const date = t.start_date
      ? new Date(t.start_date).toLocaleDateString('en-PK', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' })
      : 'TBA';
    const time = t.start_date
      ? new Date(t.start_date).toLocaleTimeString('en-PK', { hour: 'numeric', minute: '2-digit', hour12: true })
      : '';
    const canRegister = t.status === 'registration_open' && !isPast;

    return `
      <article class="tour-card glass-card ${accent}${isPast ? ' is-past' : ''}">
        <div class="tour-card-top">
          <span class="tour-platform">${platform}</span>
          <span class="tour-status ${stClass}">
            <span class="status-dot"></span>${label}
          </span>
        </div>
        <div class="tour-titles">
          <p class="tour-game">${t.game}</p>
          <h3 class="tour-name">${t.name}</h3>
        </div>
        <div class="tour-prize">
          <span class="prize-label">Prize pool</span>
          <span class="prize-value">${t.prize_pool || 'TBA'}</span>
        </div>
        <dl class="tour-meta">
          <div class="meta-row"><dt>Date</dt><dd>${date}${time ? ' · ' + time : ''}</dd></div>
          <div class="meta-row"><dt>Format</dt><dd>${t.format || 'TBA'}</dd></div>
          <div class="meta-row"><dt>Entry</dt><dd>${t.entry_fee || 'TBA'}</dd></div>
          <div class="meta-row"><dt>Slots</dt><dd>${t.slots ? t.slots + ' slots' : 'TBA'}</dd></div>
        </dl>
        <div class="tour-actions">
          <a href="/tournaments/?slug=${t.slug}" class="btn-ghost tour-btn">View Details</a>
          ${canRegister ? `<a href="/tournaments/?slug=${t.slug}#register" class="btn-primary tour-btn">Register</a>` : ''}
        </div>
      </article>
    `;
  }

  async function load() {
    document.getElementById('upcoming-grid').innerHTML = '<div class="loading-state">Loading tournaments...</div>';
    document.getElementById('past-grid').innerHTML = '<div class="loading-state">Loading...</div>';

    try {
      const res = await fetch(`${WORKER}/tournaments`);
      const all = await res.json();

      const upcoming = all.filter(t => t.status !== 'completed');
      const past = all.filter(t => t.status === 'completed');

      const upGrid = document.getElementById('upcoming-grid');
      const pastGrid = document.getElementById('past-grid');

      upGrid.innerHTML = upcoming.length
        ? upcoming.map(t => card(t, false)).join('')
        : '<div class="empty-state"><p class="empty-title">No upcoming tournaments</p><p class="empty-sub">Check back soon — new brackets drop weekly.</p></div>';

      pastGrid.innerHTML = past.length
        ? past.map(t => card(t, true)).join('')
        : '<div class="empty-state"><p class="empty-sub">No past tournaments yet.</p></div>';

    } catch (e) {
      document.getElementById('upcoming-grid').innerHTML = '<div class="empty-state"><p class="empty-sub">Failed to load tournaments. Please refresh.</p></div>';
      document.getElementById('past-grid').innerHTML = '';
    }
  }

  load();
</script>

<style>
  .page-hero { max-width: 680px; margin-bottom: 5rem; }
  .page-sub { font-size: 1.0625rem; color: var(--color-text-dim); margin-top: 1rem; max-width: 52ch; }

  .tour-section { margin-bottom: 5rem; }
  .tour-section-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .tour-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) { .tour-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .tour-grid { grid-template-columns: repeat(3, 1fr); } }

  .tour-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: transform 0.3s var(--ease-expo-out), box-shadow 0.3s;
  }
  .tour-card:hover { transform: translateY(-4px); box-shadow: 0 8px 40px rgba(101,40,247,0.2); }
  .is-past { opacity: 0.6; }
  .is-past:hover { opacity: 1; }

  .acc-purple { border-color: rgba(101,40,247,0.4) !important; }
  .acc-blue   { border-color: rgba(56,139,253,0.3) !important; }
  .acc-pink   { border-color: rgba(220,50,120,0.35) !important; }

  .tour-card-top { display: flex; align-items: center; justify-content: space-between; }
  .tour-platform {
    font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em;
    color: var(--color-brand-light);
    background: rgba(101,40,247,0.12); border: 1px solid rgba(101,40,247,0.25);
    border-radius: 6px; padding: 0.2rem 0.55rem;
  }
  .tour-status { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.6875rem; font-weight: 600; }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; }
  .st-open     { color: #4ade80; } .st-open .status-dot     { background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,0.8); }
  .st-ongoing  { color: #f59e0b; } .st-ongoing .status-dot  { background: #f59e0b; box-shadow: 0 0 8px rgba(245,158,11,0.8); }
  .st-upcoming { color: #818cf8; } .st-upcoming .status-dot { background: #818cf8; }
  .st-done     { color: var(--color-text-dim); } .st-done .status-dot { background: var(--color-text-dim); }

  .tour-titles { display: flex; flex-direction: column; gap: 0.2rem; }
  .tour-game { font-size: 0.8125rem; color: var(--color-text-dim); }
  .tour-name { font-family: 'Inter', sans-serif; font-size: 1.375rem; font-weight: 700; letter-spacing: -0.02em; color: var(--color-text); line-height: 1.1; }

  .tour-prize {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 0.875rem 1rem; border-radius: 12px;
    background: rgba(101,40,247,0.1); border: 1px solid rgba(101,40,247,0.25);
  }
  .prize-label { font-size: 0.625rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-dim); }
  .prize-value { font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: #fff; }

  .tour-meta { display: flex; flex-direction: column; gap: 0.5rem; margin: 0; flex: 1; }
  .meta-row { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; font-size: 0.8125rem; }
  .meta-row dt { color: var(--color-text-dim); flex-shrink: 0; }
  .meta-row dd { margin: 0; color: rgba(242,240,254,0.82); text-align: right; font-weight: 500; }

  .tour-actions { display: flex; gap: 0.75rem; margin-top: auto; }
  .tour-btn { flex: 1; justify-content: center; text-align: center; padding: 0.75rem 1rem; font-size: 0.875rem; }

  .loading-state { color: var(--color-text-dim); padding: 3rem; text-align: center; }

  .empty-state {
    grid-column: 1/-1; text-align: center; padding: 4rem 2rem;
    display: flex; flex-direction: column; gap: 0.5rem; align-items: center;
  }
  .empty-title { font-family: 'Inter', sans-serif; font-size: 1.25rem; font-weight: 700; color: var(--color-text); }
  .empty-sub { color: var(--color-text-dim); font-size: 0.9375rem; }
</style>