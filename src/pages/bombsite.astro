---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE, SOCIALS } from '../data/site';

const LAUNCH_DATE = '2026-05-06';
const CLOSE_DATE  = '2026-05-14';

const instagramUrl = SOCIALS.find((s) => s.name === 'Instagram')?.url ?? SITE.url;
---

<MainLayout
  title="Register | Bombsite Battles CS2 LAN Tournament"
  description="Register your team for Bombsite Battles by Arcadium. 16 teams, Double Elimination, Full LAN. CS2 tournament in Karachi, Pakistan."
>
  <div id="reg-config" data-launch={LAUNCH_DATE} data-close={CLOSE_DATE} hidden aria-hidden="true"></div>

  <section class="bombsite-hero" aria-label="Tournament details">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-content" data-reveal>
        <span class="hero-eyebrow">FULL LAN · KARACHI, PAKISTAN</span>

        <h1 class="hero-title">
          Bombsite<br /><span class="gradient-text">Battles</span>
        </h1>
        <p class="hero-by">by <strong>Arcadium</strong></p>

        <div class="stat-pills" role="list">
          <div class="stat-pill glass-card" role="listitem">
            <span class="stat-label">Prize Pool</span>
            <span class="stat-value">TBD</span>
          </div>
          <div class="stat-pill glass-card" role="listitem">
            <span class="stat-label">Teams</span>
            <span class="stat-value">16</span>
          </div>
          <div class="stat-pill glass-card" role="listitem">
            <span class="stat-label">Format</span>
            <span class="stat-value">Double Elimination</span>
          </div>
          <div class="stat-pill glass-card" role="listitem">
            <span class="stat-label">Type</span>
            <span class="stat-value">Full LAN</span>
          </div>
        </div>

        <a href="#registration-form" class="btn-primary" data-cursor="magnetic">
          Register Your Team →
        </a>
      </div>
    </div>
  </section>

  <section
    id="registration-form"
    class="section-pad reg-section"
    aria-label="Tournament registration"
  >
    <div class="container">

      <div id="registration-open">
        <header class="reg-header" data-reveal>
          <h2 class="section-heading">
            Team <span class="gradient-text">Registration</span>
          </h2>
          <p class="reg-sub">
            Registrations close <strong>May 14, 2026</strong>. Limited to 16 teams.
          </p>
          <div class="reg-countdown" aria-live="polite" aria-atomic="true">
            <span class="reg-countdown-label">Time remaining</span>
            <span id="reg-timer" class="reg-countdown-timer">--:--:--</span>
          </div>
        </header>

        <form id="reg-form" novalidate>
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;"
          />

          <div class="form-panel glass-card" data-reveal>
            <h3 class="panel-title">Team &amp; Captain</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="teamName" class="form-label">
                  Team Name <abbr title="required">*</abbr>
                </label>
                <input
                  id="teamName"
                  name="teamName"
                  type="text"
                  required
                  minlength="2"
                  maxlength="60"
                  class="form-input"
                  placeholder="e.g. Shadow Legion"
                  autocomplete="organization"
                  data-validate="name"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="captainName" class="form-label">
                  Captain Full Name <abbr title="required">*</abbr>
                </label>
                <input
                  id="captainName"
                  name="captainName"
                  type="text"
                  required
                  minlength="2"
                  maxlength="60"
                  class="form-input"
                  placeholder="Full name"
                  autocomplete="name"
                  data-validate="name"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="captainWhatsapp" class="form-label">
                  Captain WhatsApp <abbr title="required">*</abbr>
                </label>
                <input
                  id="captainWhatsapp"
                  name="captainWhatsapp"
                  type="tel"
                  required
                  maxlength="20"
                  class="form-input"
                  placeholder="+92 3XX XXXXXXX"
                  autocomplete="tel"
                  inputmode="tel"
                  data-validate="phone"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="captainNick" class="form-label">
                  Captain In-game Nick <abbr title="required">*</abbr>
                </label>
                <input
                  id="captainNick"
                  name="captainNick"
                  type="text"
                  required
                  minlength="1"
                  maxlength="30"
                  class="form-input"
                  placeholder="Your CS2 nick"
                  data-validate="nick"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
            </div>
          </div>

          <div class="players-grid">
            {
              [1, 2, 3, 4, 5].map((n) => (
                <div class="form-panel player-panel glass-card" data-reveal>
                  <div class="player-header">
                    <span class="player-badge">P{n}</span>
                    <h3 class="panel-title">Player {n}</h3>
                  </div>
                  <div class="form-grid form-grid-3">
                    <div class="form-group">
                      <label for={`player${n}Name`} class="form-label">
                        Full Name <abbr title="required">*</abbr>
                      </label>
                      <input
                        id={`player${n}Name`}
                        name={`player${n}Name`}
                        type="text"
                        required
                        minlength="2"
                        maxlength="60"
                        class="form-input"
                        placeholder="Full name"
                        data-validate="name"
                      />
                      <span class="field-error" aria-live="polite"></span>
                    </div>
                    <div class="form-group">
                      <label for={`player${n}Nick`} class="form-label">
                        In-game Nick <abbr title="required">*</abbr>
                      </label>
                      <input
                        id={`player${n}Nick`}
                        name={`player${n}Nick`}
                        type="text"
                        required
                        minlength="1"
                        maxlength="30"
                        class="form-input"
                        placeholder="Nick"
                        data-validate="nick"
                      />
                      <span class="field-error" aria-live="polite"></span>
                    </div>
                    <div class="form-group">
                      <label for={`player${n}Number`} class="form-label">
                        Number
                      </label>
                      <input
                        id={`player${n}Number`}
                        name={`player${n}Number`}
                        type="tel"
                        maxlength="20"
                        class="form-input"
                        placeholder="+92 3XX XXXXXXX"
                        inputmode="tel"
                        data-validate="phone-optional"
                      />
                      <span class="field-error" aria-live="polite"></span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="form-panel glass-card" data-reveal>
            <div class="player-header">
              <span class="player-badge player-badge-sub">SUB</span>
              <h3 class="panel-title">
                Substitute <span class="optional-tag">(optional)</span>
              </h3>
            </div>
            <div class="form-grid form-grid-3">
              <div class="form-group">
                <label for="subName" class="form-label">Full Name</label>
                <input
                  id="subName"
                  name="subName"
                  type="text"
                  minlength="2"
                  maxlength="60"
                  class="form-input"
                  placeholder="Full name"
                  data-validate="name-optional"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="subNick" class="form-label">In-game Nick</label>
                <input
                  id="subNick"
                  name="subNick"
                  type="text"
                  minlength="1"
                  maxlength="30"
                  class="form-input"
                  placeholder="Nick"
                  data-validate="nick-optional"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="subNumber" class="form-label">Number</label>
                <input
                  id="subNumber"
                  name="subNumber"
                  type="tel"
                  maxlength="20"
                  class="form-input"
                  placeholder="+92 3XX XXXXXXX"
                  inputmode="tel"
                  data-validate="phone-optional"
                />
                <span class="field-error" aria-live="polite"></span>
              </div>
            </div>
          </div>

          <div class="submit-row" data-reveal>
            <p class="submit-note">Fields marked * are required. One entry per team.</p>
            <p id="submit-error" class="submit-error-msg" hidden></p>
            <button
              id="submit-btn"
              type="submit"
              class="btn-primary btn-submit"
              data-cursor="magnetic"
            >
              Register Team →
            </button>
          </div>
        </form>
      </div>

      <div id="registration-closed" hidden>
        <div class="state-card glass-card" aria-live="polite">
          <div class="state-icon">🔒</div>
          <h2 class="section-heading">
            Registrations <span class="gradient-text">Closed</span>
          </h2>
          <p class="state-text">
            The registration window for Bombsite Battles has ended. Follow us for
            updates on the next tournament.
          </p>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            data-cursor="magnetic"
          >
            Follow @arcadium_gg →
          </a>
        </div>
      </div>

      <div id="registration-success" hidden>
        <div class="state-card glass-card" aria-live="polite">
          <div class="state-icon-success" aria-hidden="true">✓</div>
          <h2 class="section-heading">
            You&apos;re <span class="gradient-text">Registered!</span>
          </h2>
          <p class="state-text">
            Your team has been registered for Bombsite Battles. We&apos;ll reach out
            on the captain&apos;s WhatsApp to confirm your slot.
          </p>
          <a
            href={SITE.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            data-cursor="magnetic"
          >
            Message us on WhatsApp →
          </a>
        </div>
      </div>

    </div>
  </section>
</MainLayout>

<script>
  const config = document.getElementById('reg-config') as HTMLElement | null;
  const closeStr = config?.dataset.close ?? '2099-01-01';
  const closeDate = new Date(closeStr + 'T23:59:59');

  if (new Date() > closeDate) {
    document.getElementById('registration-open')?.setAttribute('hidden', '');
    document.getElementById('registration-closed')?.removeAttribute('hidden');
  }

  const timerEl = document.getElementById('reg-timer');
  function pad(n: number): string { return String(n).padStart(2, '0'); }

  function tickPage() {
    if (!timerEl) return;
    const diff = closeDate.getTime() - Date.now();
    if (diff <= 0) {
      timerEl.textContent = 'Closed';
      return;
    }
    const days  = Math.floor(diff / 864e5);
    const hours = Math.floor((diff % 864e5) / 36e5);
    const mins  = Math.floor((diff % 36e5) / 6e4);
    const secs  = Math.floor((diff % 6e4) / 1e3);
    timerEl.textContent = days > 0
      ? `${days}d ${pad(hours)}:${pad(mins)}:${pad(secs)}`
      : `${pad(hours)}:${pad(mins)}:${pad(secs)}`;
  }
  tickPage();
  setInterval(tickPage, 1000);

  const PHONE_RE = /^(\+923|03)\d{9}$/;

  function normalisePhone(v: string): string {
    return v.replace(/[\s\-().]/g, '');
  }

  function validateInput(input: HTMLInputElement): string {
    const type = input.dataset.validate ?? '';
    const v = input.value.trim();

    if (type === 'phone') {
      if (!v) return 'Phone number is required.';
      if (!PHONE_RE.test(normalisePhone(v)))
        return 'Enter a valid Pakistani number, e.g. 03001234567 or +923001234567.';
    }

    if (type === 'phone-optional') {
      if (v && !PHONE_RE.test(normalisePhone(v)))
        return 'Enter a valid Pakistani number, e.g. 03001234567 or +923001234567.';
    }

    if (type === 'name') {
      if (!v) return 'This field is required.';
      if (v.length < 2) return 'Must be at least 2 characters.';
      if (/\d/.test(v)) return 'Name should not contain numbers.';
      if (v.includes('@')) return 'Enter a name, not an email address.';
    }

    if (type === 'name-optional') {
      if (v) {
        if (v.length < 2) return 'Must be at least 2 characters.';
        if (/\d/.test(v)) return 'Name should not contain numbers.';
        if (v.includes('@')) return 'Enter a name, not an email address.';
      }
    }

    if (type === 'nick') {
      if (!v) return 'In-game nick is required.';
      if (v.length > 30) return 'Nick must be 30 characters or fewer.';
    }

    if (type === 'nick-optional') {
      if (v && v.length > 30) return 'Nick must be 30 characters or fewer.';
    }

    return '';
  }

  function showError(input: HTMLInputElement, msg: string) {
    const errSpan = input.nextElementSibling as HTMLElement | null;
    if (errSpan?.classList.contains('field-error')) errSpan.textContent = msg;
    if (msg) {
      input.classList.add('input-error');
      input.setCustomValidity(msg);
    } else {
      input.classList.remove('input-error');
      input.setCustomValidity('');
    }
  }

  document.querySelectorAll<HTMLInputElement>('[data-validate]').forEach((input) => {
    input.addEventListener('blur', () => {
      showError(input, validateInput(input));
    });
    input.addEventListener('input', () => {
      if (input.classList.contains('input-error')) {
        showError(input, validateInput(input));
      }
    });
  });

  const form = document.getElementById('reg-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const f = e.currentTarget as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errEl = document.getElementById('submit-error') as HTMLElement | null;

    if ((f.elements.namedItem('website') as HTMLInputElement | null)?.value) return;

    let firstInvalid: HTMLInputElement | null = null;
    f.querySelectorAll<HTMLInputElement>('[data-validate]').forEach((input) => {
      const msg = validateInput(input);
      showError(input, msg);
      if (msg && !firstInvalid) firstInvalid = input;
    });
    if (firstInvalid) {
      (firstInvalid as HTMLInputElement).focus();
      return;
    }

    if (!f.checkValidity()) { f.reportValidity(); return; }

    if (errEl) errEl.hidden = true;
    btn.disabled = true;
    btn.textContent = 'Submitting…';

    try {
      const res = await fetch('/api/register', {
        method: 'POST',
        body: new FormData(f),
      });

      const data = await res.json() as { ok?: boolean; error?: string };

      if (!res.ok || !data.ok) {
        if (errEl) {
          errEl.textContent = data.error ?? 'Something went wrong. Please try again.';
          errEl.hidden = false;
        }
        btn.disabled = false;
        btn.textContent = 'Register Team →';
        return;
      }

      document.getElementById('registration-open')?.setAttribute('hidden', '');
      const successEl = document.getElementById('registration-success');
      successEl?.removeAttribute('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      if (errEl) {
        errEl.textContent = 'Network error. Please check your connection and try again.';
        errEl.hidden = false;
      }
      btn.disabled = false;
      btn.textContent = 'Register Team →';
    }
  });
</script>

<style>
  .bombsite-hero {
    position: relative;
    min-height: 65vh;
    display: flex;
    align-items: center;
    padding-block: clamp(6rem, 12vw, 10rem);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 65% 55% at 50% 40%,
      rgba(101, 40, 247, 0.28) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 740px;
    margin-inline: auto;
    text-align: center;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-brand-light);
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    padding: 0.4rem 1.125rem;
    border: 1px solid rgba(101, 40, 247, 0.35);
    border-radius: 100px;
  }

  .hero-title {
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .hero-by {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: 2.75rem;
  }

  .hero-by strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .stat-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2.75rem;
  }

  .stat-pill {
    padding: 0.75rem 1.25rem;
    text-align: center;
    min-width: 110px;
  }

  .stat-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .reg-section {
    position: relative;
  }

  .reg-header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .reg-sub {
    margin-top: 0.875rem;
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .reg-countdown {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 1rem;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    border: 1px solid rgba(101, 40, 247, 0.3);
    background: rgba(101, 40, 247, 0.08);
  }

  .reg-countdown-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .reg-countdown-timer {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #a78bfa;
    font-variant-numeric: tabular-nums;
  }

  .form-panel {
    padding: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .panel-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.125rem;
  }

  @media (min-width: 640px) {
    .form-grid { grid-template-columns: 1fr 1fr; }
    .form-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .form-label abbr {
    text-decoration: none;
    color: var(--color-brand-light);
    margin-left: 0.1em;
  }

  .form-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 0.9375rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }

  .form-input::placeholder {
    color: var(--color-text-dim);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(101, 40, 247, 0.2);
  }

  .form-input:invalid:not(:placeholder-shown) {
    border-color: rgba(220, 50, 80, 0.5);
  }

  .form-input.input-error {
    border-color: rgba(220, 50, 80, 0.7);
    box-shadow: 0 0 0 3px rgba(220, 50, 80, 0.15);
  }

  .field-error {
    font-size: 0.75rem;
    color: rgba(248, 113, 113, 0.9);
    min-height: 1rem;
    line-height: 1.3;
  }

  .players-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .players-grid { grid-template-columns: 1fr 1fr; }
  }

  .player-panel { margin-bottom: 0; }

  .player-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .player-header .panel-title { margin-bottom: 0; }

  .player-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: rgba(101, 40, 247, 0.18);
    border: 1px solid rgba(101, 40, 247, 0.4);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-brand-light);
    flex-shrink: 0;
  }

  .player-badge-sub {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--color-text-muted);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
  }

  .optional-tag {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-dim);
  }

  .submit-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    text-align: center;
  }

  .submit-note {
    font-size: 0.8125rem;
    color: var(--color-text-dim);
  }

  .submit-error-msg {
    font-size: 0.875rem;
    color: rgba(248, 113, 113, 0.9);
  }

  .btn-submit {
    min-width: 200px;
    justify-content: center;
  }

  .btn-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none !important;
    box-shadow: none !important;
  }

  .state-card {
    max-width: 560px;
    margin-inline: auto;
    padding: clamp(2.5rem, 5vw, 4rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .state-icon {
    font-size: 3rem;
    line-height: 1;
  }

