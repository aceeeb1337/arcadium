---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';

const { slug } = Astro.params;
const WORKER = 'https://arcadium-website.fireonnoob.workers.dev';

const teamGames = ['CS2', 'Valorant', 'Dota 2'];
---

<MainLayout title="Tournament — Arcadium" description="Tournament details and registration at Arcadium Karachi.">
  <div class="tour-detail-page">

    <!-- Hero -->
    <section class="detail-hero section-pad" id="detail-hero">
      <div class="container">
        <div id="hero-content">
          <div class="hero-skeleton">Loading...</div>
        </div>
      </div>
    </section>

    <!-- Bracket embed -->
    <section class="bracket-section" id="bracket-section" style="display:none">
      <div class="container">
        <h2 class="bracket-title">Live Bracket</h2>
        <div class="bracket-wrap" id="bracket-wrap"></div>
      </div>
    </section>

    <!-- Registration form -->
    <section class="reg-section section-pad" id="register">
      <div class="container">
        <div class="reg-header" data-reveal>
          <SectionLabel label="Register" />
          <h2 class="section-heading">Join the<br /><span class="gradient-text">tournament</span></h2>
        </div>
        <div id="reg-form-wrap">
          <div class="loading-state">Loading registration form...</div>
        </div>
      </div>
    </section>

  </div>
</MainLayout>

<script define:vars={{ slug, WORKER, teamGames }}>
  const statusLabel = {
    upcoming: 'Coming Soon',
    registration_open: 'Registration Open',
    ongoing: 'Ongoing',
    completed: 'Completed',
  };

  const statusColor = {
    upcoming: '#818cf8',
    registration_open: '#4ade80',
    ongoing: '#f59e0b',
    completed: '#6b7280',
  };

  let tournament = null;

  async function loadTournament() {
    try {
      const res = await fetch(`${WORKER}/tournaments/${slug}`);
      if (!res.ok) throw new Error('Not found');
      tournament = await res.json();
      renderHero(tournament);
      renderForm(tournament);
      if (tournament.challonge_url) renderBracket(tournament.challonge_url);
    } catch (e) {
      document.getElementById('hero-content').innerHTML = '<p style="color:var(--color-text-dim)">Tournament not found.</p>';
      document.getElementById('reg-form-wrap').innerHTML = '';
    }
  }

  function renderHero(t) {
    const date = t.start_date
      ? new Date(t.start_date).toLocaleDateString('en-PK', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })
      : 'TBA';
    const time = t.start_date
      ? new Date(t.start_date).toLocaleTimeString('en-PK', { hour: 'numeric', minute: '2-digit', hour12: true })
      : '';
    const color = statusColor[t.status] || '#818cf8';
    const label = statusLabel[t.status] || t.status;
    const canReg = t.status === 'registration_open';

    document.title = `${t.name} — Arcadium`;

    document.getElementById('hero-content').innerHTML = `
      <div class="hero-inner">
        <div class="hero-left">
          <div class="hero-badges">
            <span class="hero-game">${t.game}</span>
            <span class="hero-status" style="color:${color}">
              <span class="status-dot" style="background:${color}"></span>${label}
            </span>
          </div>
          <h1 class="hero-title">${t.name}</h1>
          ${t.description ? `<p class="hero-desc">${t.description}</p>` : ''}
          <div class="hero-meta-grid">
            <div class="hm-item"><span class="hm-label">Date</span><span class="hm-val">${date}${time ? ' · ' + time : ''}</span></div>
            <div class="hm-item"><span class="hm-label">Format</span><span class="hm-val">${t.format || 'TBA'}</span></div>
            <div class="hm-item"><span class="hm-label">Entry Fee</span><span class="hm-val">${t.entry_fee || 'TBA'}</span></div>
            <div class="hm-item"><span class="hm-label">Slots</span><span class="hm-val">${t.slots ? t.slots + ' slots' : 'TBA'}</span></div>
            ${t.registration_deadline ? `<div class="hm-item"><span class="hm-label">Reg. Deadline</span><span class="hm-val">${new Date(t.registration_deadline).toLocaleDateString('en-PK', { day: 'numeric', month: 'short', year: 'numeric' })}</span></div>` : ''}
          </div>
          ${canReg ? `<a href="#register" class="btn-primary hero-cta">Register Now</a>` : ''}
        </div>
        <div class="hero-right">
          <div class="prize-card glass-card">
            <p class="prize-label">Prize Pool</p>
            <p class="prize-big">${t.prize_pool || 'TBA'}</p>
          </div>
        </div>
      </div>
    `;
  }

  function renderBracket(url) {
    const section = document.getElementById('bracket-section');
    const wrap = document.getElementById('bracket-wrap');
    // Convert challonge URL to embed
    let embedUrl = url;
    if (url.includes('challonge.com')) {
      embedUrl = url.replace('challonge.com/', 'challonge.com/') + '/module';
    }
    wrap.innerHTML = `<iframe src="${embedUrl}" width="100%" height="500" frameborder="0" scrolling="auto" allowtransparency="true"></iframe>`;
    section.style.display = 'block';
  }

  function playerFields(num, isSubstitute = false) {
    const label = isSubstitute ? 'Substitute Player (Optional)' : `Player ${num}`;
    const prefix = isSubstitute ? 'sub' : `p${num}`;
    const required = isSubstitute ? '' : 'required';
    return `
      <fieldset class="player-fieldset">
        <legend class="player-legend">${label}</legend>
        <div class="field-row">
          <div class="field-group">
            <label>Full Name${!isSubstitute ? ' *' : ''}</label>
            <input type="text" name="${prefix}_name" placeholder="Muhammad Ali" ${required} />
          </div>
          <div class="field-group">
            <label>Game Nickname${!isSubstitute ? ' *' : ''}</label>
            <input type="text" name="${prefix}_nick" placeholder="xNinja" ${required} />
          </div>
        </div>
        <div class="field-row">
          <div class="field-group">
            <label>Phone${!isSubstitute ? ' *' : ''}</label>
            <div class="phone-wrap">
              <span class="phone-prefix">+92</span>
              <input type="tel" name="${prefix}_phone" placeholder="3001234567" pattern="^\\+92[0-9]{10}$" ${required} />
            </div>
          </div>
          <div class="field-group">
            <label>WhatsApp${!isSubstitute ? ' *' : ''}</label>
            <div class="phone-wrap">
              <span class="phone-prefix">+92</span>
              <input type="tel" name="${prefix}_wa" placeholder="3001234567" pattern="^\\+92[0-9]{10}$" ${required} />
            </div>
          </div>
        </div>
      </fieldset>
    `;
  }

  function renderForm(t) {
    const wrap = document.getElementById('reg-form-wrap');
    const isTeam = teamGames.includes(t.game);
    const canReg = t.status === 'registration_open';

    if (!canReg) {
      const msgs = {
        upcoming: 'Registration has not opened yet. Check back soon.',
        ongoing: 'Registration is closed — this tournament is underway.',
        completed: 'This tournament has concluded.',
      };
      wrap.innerHTML = `<div class="reg-closed glass-card"><p>${msgs[t.status] || 'Registration is currently closed.'}</p></div>`;
      return;
    }

    if (isTeam) {
      wrap.innerHTML = `
        <form class="reg-form glass-card" id="reg-form">
          <div class="field-group">
            <label>Team Name *</label>
            <input type="text" name="team_name" placeholder="Team Arcadium" required />
          </div>
          ${[1,2,3,4,5].map(i => playerFields(i)).join('')}
          ${playerFields(0, true)}
          <div class="form-footer">
            <p class="form-note">All 5 players are required. No duplicate phone numbers, nicknames, or WhatsApp numbers allowed. Numbers must start with +92.</p>
            <button type="submit" class="btn-primary submit-btn" id="submit-btn">Submit Registration</button>
          </div>
          <div id="form-msg" class="form-msg" style="display:none"></div>
        </form>
      `;
    } else {
      wrap.innerHTML = `
        <form class="reg-form glass-card" id="reg-form">
          <div class="solo-fields">
            <div class="field-group">
              <label>Full Name *</label>
              <input type="text" name="solo_name" placeholder="Muhammad Ali" required />
            </div>
            <div class="field-group">
              <label>Phone Number *</label>
              <div class="phone-wrap">
                <span class="phone-prefix">+92</span>
                <input type="tel" name="solo_phone" placeholder="3001234567" required />
              </div>
            </div>
          </div>
          <div class="form-footer">
            <p class="form-note">Phone number must start with +92.</p>
            <button type="submit" class="btn-primary submit-btn" id="submit-btn">Submit Registration</button>
          </div>
          <div id="form-msg" class="form-msg" style="display:none"></div>
        </form>
      `;
    }

    // Phone prefix auto-prepend
    document.querySelectorAll('input[type="tel"]').forEach(input => {
      input.addEventListener('blur', () => {
        let val = input.value.trim();
        if (val && !val.startsWith('+92')) {
          if (val.startsWith('0')) val = val.slice(1);
          input.value = '+92' + val;
        }
      });
      input.addEventListener('focus', () => {
        if (!input.value) input.value = '+92';
      });
    });

    document.getElementById('reg-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      const msg = document.getElementById('form-msg');
      btn.disabled = true;
      btn.textContent = 'Submitting...';
      msg.style.display = 'none';

      const formData = new FormData(e.target);
      const body = { tournament_id: t.id, game: t.game };
      for (const [k, v] of formData.entries()) body[k] = v.trim();

      try {
        const res = await fetch(`${WORKER}/register`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Submission failed');

        msg.className = 'form-msg success';
        msg.textContent = '✓ Registration submitted! We\'ll confirm your slot via WhatsApp within 24 hours.';
        msg.style.display = 'block';
        e.target.reset();
      } catch (err) {
        msg.className = 'form-msg error';
        msg.textContent = '✗ ' + err.message;
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Submit Registration';
      }
    });
  }

  loadTournament();
</script>

<style>
  .detail-hero { padding-top: calc(var(--header-height) + 4rem); }

  .hero-skeleton { color: var(--color-text-dim); padding: 4rem 0; }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) { .hero-inner { grid-template-columns: 1fr 320px; } }

  .hero-badges { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
  .hero-game {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-brand-light); background: rgba(101,40,247,0.12);
    border: 1px solid rgba(101,40,247,0.25); border-radius: 6px; padding: 0.25rem 0.65rem;
  }
  .hero-status { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.8125rem; font-weight: 600; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: 1rem;
  }
  .hero-desc { color: var(--color-text-dim); font-size: 1rem; margin-bottom: 2rem; max-width: 55ch; }

  .hero-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .hm-item { display: flex; flex-direction: column; gap: 0.25rem; }
  .hm-label { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-dim); }
  .hm-val { font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 600; color: var(--color-text); }

  .hero-cta { margin-top: 0.5rem; }

  .prize-card {
    padding: 2.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .prize-label { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-dim); }
  .prize-big {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #6528f7 0%, #c4b8f8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bracket-section { padding-block: 4rem; border-top: 1px solid var(--color-border); }
  .bracket-title { font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin-bottom: 1.5rem; }
  .bracket-wrap { border-radius: 12px; overflow: hidden; border: 1px solid var(--color-border); }
  .bracket-wrap iframe { display: block; }

  .reg-section { border-top: 1px solid var(--color-border); }
  .reg-header { max-width: 600px; margin-bottom: 3rem; }

  .reg-form {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 860px;
  }

  .reg-closed {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-dim);
    max-width: 500px;
  }

  .player-fieldset {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .player-legend {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brand-light);
    padding: 0 0.5rem;
    letter-spacing: 0.02em;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) { .field-row { grid-template-columns: 1fr 1fr; } }

  .solo-fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 480px;
  }
  @media (min-width: 600px) { .solo-fields { grid-template-columns: 1fr 1fr; } }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field-group label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-dim);
    letter-spacing: 0.02em;
  }
  .field-group input {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-size: 0.9375rem;
    font-family: inherit;
    transition: border-color 0.2s;
    width: 100%;
  }
  .field-group input:focus {
    outline: none;
    border-color: var(--color-brand);
    background: rgba(101,40,247,0.06);
  }
  .field-group input::placeholder { color: rgba(242,240,254,0.25); }

  .phone-wrap { position: relative; display: flex; align-items: center; }
  .phone-prefix {
    position: absolute;
    left: 1rem;
    font-size: 0.9375rem;
    color: var(--color-brand-light);
    font-weight: 600;
    pointer-events: none;
  }
  .phone-wrap input { padding-left: 3.5rem !important; }

  .form-footer { display: flex; align-items: flex-start; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .form-note { font-size: 0.8125rem; color: var(--color-text-dim); max-width: 44ch; line-height: 1.6; }
  .submit-btn { flex-shrink: 0; }

  .form-msg {
    padding: 1rem 1.25rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .form-msg.success { background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.3); color: #4ade80; }
  .form-msg.error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }

  .loading-state { color: var(--color-text-dim); padding: 3rem; text-align: center; }
</style>
