---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import { SITE } from '../data/site';
---

<MainLayout
  title="Pricing"
  description="Arcadium pricing in Karachi. Standard PC rooms from Rs 250/hr, Premium 360Hz rooms from Rs 350/hr, PS5 from Rs 400/hr. No memberships, no hidden fees."
>
  <PageHero
    eyebrow="Pricing"
    titleLine1="Simple,"
    titleAccent="transparent pricing"
    sub="No memberships. No hidden fees. Walk in, pick your room, and play. Hourly packs that get cheaper the longer you stay."
  >
    <a
      href={SITE.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary"
      data-cursor="magnetic"
    >
      Book on WhatsApp
    </a>
    <a href="#pricing" class="btn-ghost" data-cursor="magnetic">See the rates</a>
  </PageHero>

  <Pricing />
  <FAQ />
  <CtaBand
    heading="Still deciding?"
    sub="Message us and we'll recommend the right room for your session and budget."
    whatsappMessage="Hi! I'd like help choosing the right room and package at Arcadium."
  />
</MainLayout>
