---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import PcSpecs from '../components/sections/PcSpecs.astro';
import PcRooms from '../components/sections/PcRooms.astro';
import Gallery from '../components/sections/Gallery.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import { SITE } from '../data/site';
---

<MainLayout
  title="PC Gaming"
  description="PC gaming at Arcadium Karachi. Pakistan's first 360Hz BenQ rooms with RTX 5060 and Ryzen 5 9600X. Standard from Rs 250/hr, Premium from Rs 350/hr."
>
  <PageHero
    eyebrow="PC Gaming"
    titleLine1="Built for the"
    titleAccent="uncompromising"
    sub="High-end custom rigs in private rooms. Pakistan's first 360Hz BenQ displays, RTX 5060 graphics, and pro-grade peripherals on every Premium seat."
  >
    <a
      href={`${SITE.whatsappUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary"
      data-cursor="magnetic"
    >
      Book a PC room
    </a>
    <a href="#rooms" class="btn-ghost" data-cursor="magnetic">Compare rooms</a>
  </PageHero>

  <PcSpecs />
  <PcRooms />
  <Gallery />
  <CtaBand
    heading="Lock your rig."
    sub="Standard or Premium, solo or squad. Reserve your room in under a minute."
    ctaLabel="Book a PC room"
    whatsappMessage="Hi! I want to book a PC gaming room at Arcadium. Please confirm availability."
  />
</MainLayout>
